        "/accounts/{account_id}/workers/services",
        "/accounts/{account_id}/workers/subdomain"
      ],
      "hawaiiConfig": "workers-hawaii.json",
      "namespace": "Fidelity.CloudEdge.Management.Workers",
      "postProcessors": [
        {
          "name": "discriminators",
          "args": {
            "listType": "workersbindings",
            "itemType": "workers_binding_item",
            "kindPrefix": "workersbindingkind"
          }
        },
        {
          "name": "jobject-multipart"
        },
        {
          "name": "missing-body-params",
          "args": {
            "methodName": "WorkerPutScriptSecret",
            "bodyType": "Types.workersbindingkindsecrettext"
          }
        }
      ],
      "status": "active"
    },
