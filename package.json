{
  "name": "fidelity-cloudedge",
  "version": "0.1.0",
  "description": "F# Framework extension for substrate-agnostic actor model on Cloudflare edge",
  "private": true,
  "scripts": {
    "install-glutinum": "npm install -g @glutinum/cli",
    "generate": "bash ./generators/scripts/update-and-generate.sh",
    "generate:runtime": "bash ./generators/scripts/generate-runtime.sh",
    "generate:management": "bash ./generators/scripts/generate-management.sh",
    "postinstall": "echo 'Run npm run generate to create F# bindings'",
    "test": "cd tests/CloudEdge.Tests && dotnet run",
    "test:watch": "cd tests/CloudEdge.Tests && dotnet watch run",
    "test:coverage": "cd tests/CloudEdge.Tests && dotnet test /p:CollectCoverage=true /p:CoverletOutputFormat=opencover",
    "test:fable": "cd tests/CloudEdge.Tests && npm run test:fable",
    "build": "dotnet build",
    "clean": "dotnet clean",
    "restore": "dotnet restore"
  },
  "devDependencies": {
    "@cloudflare/ai": "^1.0.63",
    "@cloudflare/pages-shared": "^0.13.75",
    "@cloudflare/vitest-pool-workers": "^0.5.39",
    "@cloudflare/workers-types": "4.20260307.1",
    "@types/node": "^22.10.2",
    "miniflare": "^3.20241106.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.71.0"
  },
  "optionalDependencies": {
    "@cloudflare/kv-asset-handler": "^0.3.4",
    "@cloudflare/workers-shared": "^0.11.0"
  }
}
